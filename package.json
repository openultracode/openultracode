{
  "name": "openultracode",
  "version": "0.1.0",
  "description": "Local CLI for parallel coding agents with adaptive model routing.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/openultracode/openultracode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openultracode/openultracode.git"
  },
  "bugs": {
    "url": "https://github.com/openultracode/openultracode/issues"
  },
  "keywords": [
    "ai-agents",
    "agentic-coding",
    "cli",
    "codex",
    "coding-agents",
    "openrouter",
    "orchestration",
    "worktrees"
  ],
  "bin": {
    "openultracode": "dist/bin/ouc.js",
    "ouc": "dist/bin/ouc.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm test && npm run typecheck && npm run build && npm pack --dry-run",
    "release:check": "npm run verify && npm publish --dry-run"
  },
  "dependencies": {
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20.18"
  }
}
